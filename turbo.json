{
    "$schema": "https://turbo.build/schema.json",
    "globalEnv": [
        "ADMIN_PASSWORD",
        "CF_API_TOKEN",
        "CF_ZONE_ID"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                ".next/**",
                "!.next/cache/**"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "clean": {
            "cache": false
        }
    }
}