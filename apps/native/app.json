{
  "expo": {
    "name": "BeanPool Pillar",
    "slug": "beanpool-pillar",
    "version": "1.0.15",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "beanpool",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#ffffff",
      "image": "./assets/images/logo.png",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.beanpool.pillar",
      "buildNumber": "7",
      "associatedDomains": [
        "applinks:beanpool.org",
        "applinks:*.beanpool.org",
        "applinks:beanpool.org",
        "applinks:*.beanpool.org"
      ],
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "fetch"
        ],
        "NSLocationWhenInUseUsageDescription": "BeanPool relies exclusively on your device's GPS to plot your Sovereign Identity on the community map, enabling you to physically discover neighboring Marketplace needs and offers.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 18,
      "package": "org.beanpool.pillar",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDpRO8fjR8U-7pyFPbjvro6FCAPLZL2bBo"
        }
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "beanpool.org"
            },
            {
              "scheme": "https",
              "host": "*.beanpool.org"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "BeanPool relies exclusively on your device's GPS to plot your Sovereign Identity on the community map, enabling you to physically discover neighboring Marketplace needs and offers.",
          "isIosBackgroundLocationEnabled": false
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "17a2a61a-9cbe-457e-bb10-84d8a666e6eb"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/17a2a61a-9cbe-457e-bb10-84d8a666e6eb"
    }
  }
