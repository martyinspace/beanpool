# BeanPool Environment Variables
# Copy to .env and fill in your values

CF_API_TOKEN=your-cloudflare-api-token
CF_ZONE_ID=your-cloudflare-zone-id

# Used for Universal Links in the apple-app-site-association file
# Get this 10-character code from the Apple Developer Portal -> Membership Details
APPLE_TEAM_ID=your-10-char-apple-team-id
